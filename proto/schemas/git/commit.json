{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rommel.dev/schemas/git/commit.json",
  "title": "GitCommit",
  "description": "git.commit — create a commit from the current index or specific files.",
  "$defs": {
    "GitCommitRequest": {
      "title": "GitCommitRequest",
      "type": "object",
      "required": ["message"],
      "properties": {
        "message": { "type": "string" },
        "files": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Optional list of files to stage before committing. If empty, commits whatever is already staged."
        }
      },
      "additionalProperties": false
    },
    "GitCommitResponse": {
      "title": "GitCommitResponse",
      "type": "object",
      "required": ["oid", "message"],
      "properties": {
        "oid": { "type": "string", "description": "The commit SHA." },
        "message": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "oneOf": [
    { "$ref": "#/$defs/GitCommitRequest" },
    { "$ref": "#/$defs/GitCommitResponse" }
  ]
}
