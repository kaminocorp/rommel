# Reference: every environment variable the sandbox-daemon reads. Documented
# here so a future operator can see the full surface area without grepping
# `sandbox-daemon/internal/config`. The image bakes none of these except
# ROMMEL_WORKSPACE_ROOT and ROMMEL_TOKEN_PUBKEY (via /etc/rommel/token.pubkey
# + entrypoint.sh).

# TCP port the HTTP/WS server binds to. Defaults to 7777 in the daemon if
# unset. Match this to fly.toml's internal_port.
ROMMEL_PORT=7777

# Absolute path that bounds every fs.* primitive. Set by the Dockerfile ENV;
# overridable per-machine if the backend ever mounts a different path.
ROMMEL_WORKSPACE_ROOT=/workspace

# Workspace id (UUID-ish string from the backend). REQUIRED. The daemon
# rejects any token whose `wid` claim doesn't match. Set per-machine at
# machine create time.
ROMMEL_WID=

# Ed25519 public key, PEM-encoded (the full -----BEGIN PUBLIC KEY----- block
# inline). REQUIRED. The entrypoint loads it from /etc/rommel/token.pubkey
# at boot, so this var doesn't normally need to be set explicitly.
ROMMEL_TOKEN_PUBKEY=
