# rommel-backend environment variables. Copy to `.env.local` for local dev;
# in production these are set via `fly secrets set`. All keys are also read by
# the same `Settings` class via pydantic-settings (env_prefix=ROMMEL_).

# Database (asyncpg URL used by the FastAPI app — RLS-bound `app_user`).
ROMMEL_DATABASE_URL=postgresql+asyncpg://app_user:app_pw@localhost:5432/rommel

# Database (sync URL used by Alembic — privileged role that owns the schema).
# Risk 4.2: must NOT be the same role as the app — Postgres RLS exempts table
# owners by default, so the app would silently bypass policies.
ROMMEL_DATABASE_MIGRATE_URL=postgresql://rommel:rommel@localhost:5432/rommel

# Ed25519 PEM contents (NOT a file path), mirroring the daemon's
# ROMMEL_TOKEN_PUBKEY convention. Generate via:
#   openssl genpkey -algorithm ed25519 -out priv.pem
#   openssl pkey -in priv.pem -pubout -out pub.pem   # → bake into workspace-image
ROMMEL_TOKEN_PRIVKEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Daemon URL template. `{wid}` is interpolated per-session.
# Phase 0 production (Flycast public WSS on rommel-workspaces):
#   wss://{wid}.workspaces.rommel.dev/ws   (or the exact hostname Flycast gives)
# Local dev:
#   ws://localhost:7777/ws
ROMMEL_DAEMON_URL_TEMPLATE=ws://localhost:7777/ws

# Session-token TTL in seconds. Default 300 (5 min). Daemon enforces `exp`.
ROMMEL_TOKEN_TTL_SECONDS=300

# Supabase JWKS endpoint — used by the auth seam to validate inbound user JWTs.
# Find it at: <SUPABASE_URL>/auth/v1/.well-known/jwks.json
ROMMEL_SUPABASE_JWKS_URL=https://<project>.supabase.co/auth/v1/.well-known/jwks.json

# Supabase audience (Supabase issues tokens with aud="authenticated").
ROMMEL_SUPABASE_JWT_AUDIENCE=authenticated

# Fly Machines API token. Only required in production; the local dev path
# stubs out the orchestrator.
ROMMEL_FLY_API_TOKEN=

# Fly app name for workspace machines (set by Phase 3 — `rommel-workspaces`).
ROMMEL_FLY_WORKSPACES_APP=rommel-workspaces

# Workspace image ref to pin per machine create.
ROMMEL_WORKSPACE_IMAGE=registry.fly.io/rommel-workspaces:latest

# Default scope vocabulary granted on a session token. The daemon's per-route
# table enforces scope:primitive mapping at the wire.
ROMMEL_DEFAULT_SCOPES=fs:rw,pty:rw,git:rw,funnel:rw,policy:r

# CORS origins for the API. Defaults to `*` (dev). In production set to the
# exact frontend origin(s), comma-separated, e.g.:
#   ROMMEL_CORS_ORIGINS=https://rommel.dev,https://www.rommel.dev
ROMMEL_CORS_ORIGINS=*
