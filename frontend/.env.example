# Frontend env — public (NEXT_PUBLIC_*) is baked into the client bundle.
# Server-only secrets (no NEXT_PUBLIC_ prefix) are read only by RSC / route
# handlers / middleware; they MUST NOT be imported from "use client" code.

# Required — every page.
NEXT_PUBLIC_BACKEND_URL=http://localhost:8080

# Required — Supabase project URL + anon key (anon is safe to ship).
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional, server-only. Never prefix with NEXT_PUBLIC_.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
